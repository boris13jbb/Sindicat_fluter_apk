rules_version = '2';
// firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function hasUserProfile() {
      return isSignedIn()
        && firestore.exists(
          /databases/(default)/documents/users/$(request.auth.uid)
        );
    }

    function isAdmin() {
      return hasUserProfile()
        && firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        ).data.role in ['SUPERADMIN', 'ADMIN'];
    }

    function isCandidateImageUpload() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Nueva convención: elections/{electionId}/candidates/{candidateId}/{archivo}
    match /elections/{electionId}/candidates/{candidateId}/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isCandidateImageUpload();
      allow delete: if isAdmin();
    }

    // Compatibilidad: fotos ya subidas bajo candidate_photos/
    match /elections/{electionId}/candidate_photos/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isCandidateImageUpload();
      allow delete: if isAdmin();
    }
  }
}
