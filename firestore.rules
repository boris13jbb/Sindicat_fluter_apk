rules_version = '2';
// Reglas para el Sistema de Voto Sindicato (Flutter).
// Despliega con: firebase deploy --only firestore

service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== FUNCIONES AUXILIARES ====================
    
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function electionIsOpen(electionId) {
      let election = get(/databases/$(database)/documents/elections/$(electionId)).data;
      return election.isActive == true
        && election.isVisibleToVoters == true
        && election.startDate is number
        && election.endDate is number
        && election.startDate <= request.time.toMillis()
        && election.endDate >= request.time.toMillis();
    }

    function candidateExists(electionId, candidateId) {
      return exists(/databases/$(database)/documents/elections/$(electionId)/candidates/$(candidateId));
    }

    function userVoteId(electionId) {
      return electionId + '_' + request.auth.uid;
    }

    function userVotePath(electionId) {
      return /databases/$(database)/documents/elections/$(electionId)/votes/$(userVoteId(electionId));
    }

    function ownVoteCreatedInRequest(electionId) {
      return !exists(userVotePath(electionId))
        && existsAfter(userVotePath(electionId))
        && getAfter(userVotePath(electionId)).data.electionId == electionId
        && getAfter(userVotePath(electionId)).data.userId == request.auth.uid;
    }
    
    // Obtener rol del usuario (maneja caso donde documento no existe)
    function getUserRole() {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath)
        ? get(userDocPath).data.role
        : 'USER';
    }
    
    // Verificar si es superadmin
    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'SUPERADMIN';
    }
    
    // Verificar si es admin o superadmin
    function isAdmin() {
      return isAuthenticated() && getUserRole() in ['SUPERADMIN', 'ADMIN'];
    }
    
    // Verificar si es operador de asistencia
    function isOperator() {
      return isAuthenticated() && getUserRole() in ['SUPERADMIN', 'ADMIN', 'OPERADOR_ASISTENCIA'];
    }

    function memberPath(memberId) {
      return /databases/$(database)/documents/members/$(memberId);
    }

    function memberMatchesEmployeeNumber(memberId, employeeNumber) {
      return memberId is string
        && employeeNumber is string
        && exists(memberPath(memberId))
        && (
          get(memberPath(memberId)).data.workerCode == employeeNumber ||
          get(memberPath(memberId)).data.memberNumber == employeeNumber ||
          get(memberPath(memberId)).data.documentId == employeeNumber
        );
    }

    function validOptionalUserMemberId() {
      return !('memberId' in request.resource.data) ||
        request.resource.data.memberId == null ||
        memberMatchesEmployeeNumber(
          request.resource.data.memberId,
          request.resource.data.employeeNumber
        );
    }

    function validMemberIdBackfill() {
      return !changedKeys().hasAny(['memberId']) || (
        (!('memberId' in resource.data) ||
          resource.data.memberId == null ||
          resource.data.memberId == '') &&
        memberMatchesEmployeeNumber(
          request.resource.data.memberId,
          request.resource.data.employeeNumber
        )
      );
    }

    function isValidAuditLogCreate() {
      return request.resource.data.keys().hasOnly([
          'action',
          'entityType',
          'entityId',
          'userId',
          'userName',
          'timestamp',
          'changes',
          'description',
          'platform',
          'ipAddress',
        ])
        && request.resource.data.keys().hasAll([
          'action',
          'entityType',
          'entityId',
          'userId',
          'timestamp',
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.action in [
          'create',
          'update',
          'delete',
          'vote',
          'import_',
          'login',
          'logout',
          'attendance',
        ]
        && request.resource.data.entityType in [
          'member',
          'election',
          'candidate',
          'vote',
          'attendanceEvent',
          'attendanceRecord',
          'user',
          'import_',
        ]
        && request.resource.data.entityId is string
        && request.resource.data.timestamp is number
        && (!('userName' in request.resource.data) ||
          request.resource.data.userName == null ||
          request.resource.data.userName is string)
        && (!('description' in request.resource.data) ||
          request.resource.data.description == null ||
          request.resource.data.description is string)
        && (!('platform' in request.resource.data) ||
          request.resource.data.platform == null ||
          request.resource.data.platform is string)
        && (!('ipAddress' in request.resource.data) ||
          request.resource.data.ipAddress == null ||
          request.resource.data.ipAddress is string)
        && (!('changes' in request.resource.data) ||
          request.resource.data.changes == null ||
          request.resource.data.changes is map);
    }

    // ==================== USUARIOS ====================
    
    match /users/{userId} {
      // Leer: usuario autenticado puede leer su propio documento
      allow read: if isOwner(userId);
      
      // Crear: auto-registro solo como votante, sin escalación de privilegios
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'email',
          'displayName',
          'role',
          'employeeNumber',
          'memberId',
          'createdAt',
          'updatedAt',
          'isActive',
        ])
        && request.resource.data.keys().hasAll(['email', 'role'])
        && request.resource.data.email is string
        && request.resource.data.role == 'VOTER'
        && (!('displayName' in request.resource.data) ||
          request.resource.data.displayName == null ||
          request.resource.data.displayName is string)
        && (!('employeeNumber' in request.resource.data) ||
          request.resource.data.employeeNumber == null ||
          request.resource.data.employeeNumber is string)
        && validOptionalUserMemberId();
      
      // Actualizar: superadmin puede actualizar cualquier usuario, o el usuario puede actualizar su propio perfil
      // IMPORTANTE: No permitir que usuarios cambien su propio rol (escalación de privilegios)
      allow update: if isSuperAdmin() || (
        isOwner(userId) &&
        request.resource.data.role == resource.data.role &&
        changedKeys().hasOnly([
          'email',
          'displayName',
          'employeeNumber',
          'memberId',
          'updatedAt',
        ])
        && validMemberIdBackfill()
      );
      
      // Eliminar: solo superadmin
      allow delete: if isSuperAdmin();
    }

    // ==================== SOCIOS (MEMBERS) ====================
    
    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isSuperAdmin() || isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ==================== ELECCIONES ====================

    match /elections/{electionId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      
      // Permitir actualización parcial solo para campos de conteo de votos
      // Esto permite que usuarios VOTER incrementen totalVotes sin poder modificar otros campos
      allow update: if isAdmin() || (
        isAuthenticated() && 
        electionIsOpen(electionId) &&
        ownVoteCreatedInRequest(electionId) &&
        changedKeys().hasOnly(['totalVotes', 'updatedAt']) &&
        request.resource.data.totalVotes is number &&
        request.resource.data.totalVotes == resource.data.totalVotes + 1 &&
        request.resource.data.updatedAt is number
      );
      
      allow delete: if isSuperAdmin();

      // Candidatos
      match /candidates/{candidateId} {
        allow read: if isAuthenticated();
        allow create: if isAdmin();
        
        // Permitir actualización parcial solo para campo voteCount
        // Esto permite que usuarios VOTER incrementen voteCount sin poder modificar otros campos
        allow update: if isAdmin() || (
          isAuthenticated() && 
          electionIsOpen(electionId) &&
          ownVoteCreatedInRequest(electionId) &&
          getAfter(userVotePath(electionId)).data.candidateId == candidateId &&
          changedKeys().hasOnly(['voteCount']) &&
          request.resource.data.voteCount is number &&
          request.resource.data.voteCount == resource.data.voteCount + 1
        );
        
        allow delete: if isSuperAdmin();
      }

      // Votos
      match /votes/{voteId} {
        // Cualquier usuario autenticado puede verificar si ya votó (leer su propio voto)
        // Admin/superadmin pueden leer todos los votos para reportes
        allow read: if isAdmin() || (
          isAuthenticated() &&
          voteId == userVoteId(electionId)
        );
        allow create: if isAuthenticated()
                && request.resource.data.keys().hasOnly([
                  'electionId',
                  'userId',
                  'candidateId',
                  'votedAt',
                ])
                && electionIsOpen(electionId)
                && request.resource.data.electionId == electionId
                && request.resource.data.userId == request.auth.uid
                && request.resource.data.candidateId is string
                && candidateExists(electionId, request.resource.data.candidateId)
                && request.resource.data.votedAt == request.time
                && voteId == userVoteId(electionId);
        allow update, delete: if false; // Los votos son inmutables
      }
    }

    // ==================== EVENTOS DE ASISTENCIA ====================
    
    // Sistema nuevo: attendance_events con subcolecciones
    match /attendance_events/{eventId} {
      allow read: if isAuthenticated();
      // Alta alineada con eventos legacy: admin y operador de asistencia
      allow create: if isOperator();
      allow update: if isOperator();
      allow delete: if isSuperAdmin();

      // Asistencias del evento
      match /asistencias/{asistenciaId} {
        allow read: if isAuthenticated();
        allow create: if isOperator();
        allow update: if isOperator();
        allow delete: if isSuperAdmin();
      }
    }

    // ==================== EVENTOS ANTIGUOS ====================
    // Colecciones legacy para compatibilidad con Android
    
    match /eventos/{eventoId} {
      allow read: if isAuthenticated();
      allow create, update: if isOperator();
      allow delete: if isSuperAdmin();

      match /asistencias/{asistenciaId} {
        allow read: if isAuthenticated();
        allow create, update: if isOperator();
        allow delete: if isSuperAdmin();
      }
    }

    match /personas/{personaId} {
      allow read: if isAuthenticated();
      allow create, update: if isOperator();
      allow delete: if isSuperAdmin();
    }

    match /asistencias/{asistenciaId} {
      allow read: if isAuthenticated();
      allow create, update: if isOperator();
      allow delete: if isSuperAdmin();
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create, update: if isOperator();
      allow delete: if isSuperAdmin();
    }

    // ==================== REGISTROS DE AUDITORÍA ====================
    
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidAuditLogCreate(); // Solo append
      allow update, delete: if false; // Inmutables
    }

    // ==================== LOGS DE IMPORTACIÓN ====================
    
    match /import_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ==================== REGLA POR DEFECTO ====================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
