rules_version = '2';
// Reglas para el Sistema de Voto Sindicato (Flutter).
// Despliega con: firebase deploy --only firestore

service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== FUNCIONES AUXILIARES ====================
    
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }
    
    // Obtener rol del usuario (maneja caso donde documento no existe)
    function getUserRole() {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath)
        ? get(userDocPath).data.role
        : 'USER';
    }
    
    // Verificar si es superadmin
    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'SUPERADMIN';
    }
    
    // Verificar si es admin o superadmin
    function isAdmin() {
      return isAuthenticated() && getUserRole() in ['SUPERADMIN', 'ADMIN'];
    }
    
    // Verificar si es operador de asistencia
    function isOperator() {
      return isAuthenticated() && getUserRole() in ['SUPERADMIN', 'ADMIN', 'OPERADOR_ASISTENCIA'];
    }

    // ==================== USUARIOS ====================
    
    match /users/{userId} {
      // Leer: usuario autenticado puede leer su propio documento
      allow read: if isOwner(userId);
      
      // Crear: auto-registro solo como votante, sin escalación de privilegios
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'email',
          'displayName',
          'role',
          'employeeNumber',
          'createdAt',
          'updatedAt',
          'isActive',
        ])
        && request.resource.data.keys().hasAll(['email', 'role'])
        && request.resource.data.email is string
        && request.resource.data.role == 'VOTER'
        && (!('displayName' in request.resource.data) ||
          request.resource.data.displayName == null ||
          request.resource.data.displayName is string)
        && (!('employeeNumber' in request.resource.data) ||
          request.resource.data.employeeNumber == null ||
          request.resource.data.employeeNumber is string);
      
      // Actualizar: superadmin puede actualizar cualquier usuario, o el usuario puede actualizar su propio perfil
      // IMPORTANTE: No permitir que usuarios cambien su propio rol (escalación de privilegios)
      allow update: if isSuperAdmin() || (
        isOwner(userId) &&
        request.resource.data.role == resource.data.role &&
        changedKeys().hasOnly([
          'email',
          'displayName',
          'employeeNumber',
          'updatedAt',
        ])
      );
      
      // Eliminar: solo superadmin
      allow delete: if isSuperAdmin();
    }

    // ==================== SOCIOS (MEMBERS) ====================
    
    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ==================== ELECCIONES ====================

    match /elections/{electionId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      
      // Permitir actualización parcial solo para campos de conteo de votos
      // Esto permite que usuarios VOTER incrementen totalVotes sin poder modificar otros campos
      allow update: if isAdmin() || (
        isAuthenticated() && 
        changedKeys().hasOnly(['totalVotes', 'updatedAt']) &&
        request.resource.data.totalVotes is number &&
        request.resource.data.totalVotes == resource.data.totalVotes + 1
      );
      
      allow delete: if isSuperAdmin();

      // Candidatos
      match /candidates/{candidateId} {
        allow read: if isAuthenticated();
        allow create: if isAdmin();
        
        // Permitir actualización parcial solo para campo voteCount
        // Esto permite que usuarios VOTER incrementen voteCount sin poder modificar otros campos
        allow update: if isAdmin() || (
          isAuthenticated() && 
          changedKeys().hasOnly(['voteCount']) &&
          request.resource.data.voteCount is number &&
          request.resource.data.voteCount == resource.data.voteCount + 1
        );
        
        allow delete: if isSuperAdmin();
      }

      // Votos
      match /votes/{voteId} {
        // Cualquier usuario autenticado puede verificar si ya votó (leer su propio voto)
        // Admin/superadmin pueden leer todos los votos para reportes
        allow read: if isAdmin() || (
          isAuthenticated() &&
          resource.data.userId == request.auth.uid
        );
        allow create: if isAuthenticated()
                && request.resource.data.keys().hasOnly([
                  'electionId',
                  'userId',
                  'candidateId',
                  'votedAt',
                ])
                && request.resource.data.electionId == electionId
                && request.resource.data.userId == request.auth.uid
                && voteId == request.resource.data.electionId + '_' + request.resource.data.userId;
        allow update, delete: if false; // Los votos son inmutables
      }
    }

    // ==================== EVENTOS DE ASISTENCIA ====================
    
    // Sistema nuevo: attendance_events con subcolecciones
    match /attendance_events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isOperator();
      allow delete: if isSuperAdmin();

      // Asistencias del evento
      match /asistencias/{asistenciaId} {
        allow read: if isAuthenticated();
        allow create: if isOperator();
        allow update: if isOperator();
        allow delete: if isSuperAdmin();
      }
    }

    // ==================== EVENTOS ANTIGUOS ====================
    // Colecciones legacy para compatibilidad con Android
    
    match /eventos/{eventoId} {
      allow read: if isAuthenticated();
      allow create, update: if isOperator();
      allow delete: if isSuperAdmin();

      match /asistencias/{asistenciaId} {
        allow read: if isAuthenticated();
        allow create, update: if isOperator();
        allow delete: if isSuperAdmin();
      }
    }

    match /personas/{personaId} {
      allow read: if isAuthenticated();
      allow create, update: if isOperator();
      allow delete: if isSuperAdmin();
    }

    match /asistencias/{asistenciaId} {
      allow read: if isAuthenticated();
      allow create, update: if isOperator();
      allow delete: if isSuperAdmin();
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create, update: if isOperator();
      allow delete: if isSuperAdmin();
    }

    // ==================== REGISTROS DE AUDITORÍA ====================
    
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // Solo append
      allow update, delete: if false; // Inmutables
    }

    // ==================== LOGS DE IMPORTACIÓN ====================
    
    match /import_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSuperAdmin();
      allow update, delete: if false;
    }

    // ==================== REGLA POR DEFECTO ====================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
